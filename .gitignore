.gitnexus

# Belt-and-suspenders — Datadog/runtime secrets live at ~/.config/lazyexplorer/.env.local (outside repo).
# Reject any stray copy that lands inside the working tree.
.env
.env.*

# Reference-only clones (root CLAUDE.md §Reference Code) — read for patterns, never compiled in.
tmp/

# Local build artifacts — `go build` drops the binary at repo root; goreleaser uses dist/.
/lazyexplorer
dist/

# OS / editor noise.
.DS_Store
*.swp

# Local OMC ledger archive — kept on disk for history but never committed.
.omc/

# Cloudflare Wrangler local cache/state from `wrangler pages` deploys (landing page).
.wrangler/

# Ruff (Python linter) cache — stray artifact from tooling runs, not part of this Go project.
.ruff_cache/

# User-local Claude Code config (skills, settings) — lives on the developer's machine,
# not in the public repo. AGENTS.md (GitNexus index, project-relevant) is committed.
.claude/

# Spec Kit scaffold from `specify init` — a tooling workspace, not part of the app.
my-project/

# External Claude Code skills dropped under .github/skills/ — tooling on the
# developer's machine, not app code. .github/workflows/ stays committed.
.github/skills/
